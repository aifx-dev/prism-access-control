# Copiar a .env.admin en la misma carpeta que docker-compose.yml
# cp .env.admin.example .env.admin

# La imagen admin actual es nginx + estáticos; Vite/Clerk van en build-time.
# Este archivo queda para variables de interpolación del compose y futuros usos.

# ADMIN_PORT=5173
# ADMIN_IMAGE=aifxnetworks/edge-guard-admin:latest

# Línea sin efecto en la imagen actual (garantiza un KEY=VAL si el motor lo exige)
EDGE_GUARD_ADMIN_ENV=1
