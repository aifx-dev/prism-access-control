# Copiar a /etc/nginx/sites-available/ y enlazar en sites-enabled.
# Este archivo se incluye dentro de http { }; no dupliques map/limit_* en otro sitio con los mismos nombres.
# Ajusta server_name (añade IP o default_server) si entras sin dominio.

# WebSocket: Connection según presencia de Upgrade (evita cabeceras incorrectas en REST).
map $http_upgrade $edge_guard_connection_upgrade {
    default upgrade;
    ''      close;
}

# Rate limit por IP (mitiga abuso; sube rate/burst si ves 503 legítimos).
limit_req_zone $binary_remote_addr zone=edge_guard_panel:10m rate=30r/s;
limit_req_zone $binary_remote_addr zone=edge_guard_api:10m rate=20r/s;
limit_req_zone $binary_remote_addr zone=edge_guard_ws:10m rate=5r/s;

# 1. Panel (SPA en 5173). WebSocket /api/v1/ws/* → backend 8000.
server {
    listen 80;
    server_name prism.com.co www.prism.com.co;

    server_tokens off;

    # Límite de subida (imágenes / identify); ajusta si el backend exige más.
    client_max_body_size 30m;
    client_body_timeout 60s;
    client_header_timeout 15s;
    send_timeout 60s;

    # Cabeceras de seguridad en respuestas al navegador (no sustituyen HTTPS).
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "accelerometer=(), camera=(self), geolocation=(), microphone=(), payment=()" always;

    location /api/v1/ws/ {
        limit_req zone=edge_guard_ws burst=10 nodelay;

        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $edge_guard_connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }

    location / {
        limit_req zone=edge_guard_panel burst=80 nodelay;

        proxy_pass http://127.0.0.1:5173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $edge_guard_connection_upgrade;
        proxy_read_timeout 86400;
    }
}

# 2. API por subdominio.
server {
    listen 80;
    server_name api-prism.com.co;

    server_tokens off;

    client_max_body_size 30m;
    client_body_timeout 60s;
    client_header_timeout 15s;
    send_timeout 60s;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location /api/v1/ws/ {
        limit_req zone=edge_guard_ws burst=10 nodelay;

        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $edge_guard_connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }

    location / {
        limit_req zone=edge_guard_api burst=40 nodelay;

        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# --- HTTPS (cuando tengas certificados) ---
# El panel usa getUserMedia (reconocimiento facial): los navegadores solo permiten cámara en contexto seguro (HTTPS o localhost). Sin TLS la cámara no arrancará.
# Duplica cada server con listen 443 ssl http2; ssl_certificate ...; ssl_certificate_key ...;
# Añade en ambos bloques 443 (panel y API):
#   add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
# En 80, redirección opcional: return 301 https://$host$request_uri;
# Certbot suele insertar ssl_* y HSTS por ti.
