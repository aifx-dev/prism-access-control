# Copiar a .env.backend en la misma carpeta que docker-compose.yml
# cp .env.backend.example .env.backend

# ── Obligatorio (aplicación) ──
# Postgres en el host (desde el contenedor usa IP del host, ej. 172.17.0.1, no "localhost")
POSTGRES_URL=postgresql+asyncpg://usuario:clave@HOST:5432/edge_guard
JWT_SECRET=cambia_por_un_secreto_largo_y_aleatorio

# ── Opcionales ──
RUN_MIGRATIONS=0
# Debe coincidir con el volumen del compose (media_files → /app/media). Otra ruta sin permisos de escritura falla al guardar fotos.
MEDIA_PATH=/app/media
SIMILARITY_THRESHOLD=0.55
DEBOUNCE_SECONDS=10
JWT_EXPIRE_HOURS=8
JWT_ALGORITHM=HS256

# Interpolación del compose (opcional): crea un .env junto al compose con estas claves si las necesitas
# BACKEND_PORT=8000
# BACKEND_IMAGE=aifxnetworks/edge-guard-backend:latest

# Opcionales conexión BD (ver backend/.env.example en el repo)
# POSTGRES_POOL_RECYCLE=280
# POSTGRES_POOL_TIMEOUT=60
# POSTGRES_CONNECT_TIMEOUT=60
# POSTGRES_SSL_DISABLE=true
